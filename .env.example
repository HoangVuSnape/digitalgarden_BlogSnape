# Site Configuration
# The name displayed in the site header
SITE_NAME_HEADER=Digital Garden

# The main language of your site
SITE_MAIN_LANGUAGE=en

# The base URL of your site (e.g., yourdomain.com or https://yourdomain.com)
# Leave empty for local development
SITE_BASE_URL=

# Timestamp Settings
# Show creation timestamp on notes
SHOW_CREATED_TIMESTAMP=false

# Format for displaying timestamps (using date-fns format)
# Examples: "MMM dd, yyyy h:mm a", "yyyy-MM-dd", "dd/MM/yyyy"
TIMESTAMP_FORMAT=MMM dd, yyyy h:mm a

# Show last updated timestamp on notes
SHOW_UPDATED_TIMESTAMP=false

# Note Icon Settings
# Default icon for notes (emoji or icon name)
NOTE_ICON_DEFAULT=

# Show note icons in the title
NOTE_ICON_TITLE=false

# Show note icons in the file tree
NOTE_ICON_FILETREE=false

# Show note icons in internal links
NOTE_ICON_INTERNAL_LINKS=false

# Show note icons in backlinks
NOTE_ICON_BACK_LINKS=false

# Theme Settings
# Custom CSS for style settings
STYLE_SETTINGS_CSS=

# Additional body classes for styling
STYLE_SETTINGS_BODY_CLASSES=

# Use full resolution images (true/false)
# Set to false to use optimized images for better performance
USE_FULL_RESOLUTION_IMAGES=false

# Theme URL (URL to a custom Obsidian theme CSS file)
# Example: https://raw.githubusercontent.com/username/theme-repo/HEAD/theme.css
THEME=

# Base theme (light/dark)
BASE_THEME=dark

# Digital Garden Plugin Settings
# Enable home link
dgHomeLink=true

# Pass frontmatter to pages
dgPassFrontmatter=false

# Show backlinks
dgShowBacklinks=true

# Show local graph
dgShowLocalGraph=true

# Show inline title
dgShowInlineTitle=true

# Show file tree
dgShowFileTree=true

# Enable search
dgEnableSearch=true

# Show table of contents
dgShowToc=true

# Enable link preview
dgLinkPreview=true

# Show tags
dgShowTags=true

# Environment (development/production)
# This is typically set by the build process, not in .env
# ELEVENTY_ENV=dev

# Node.js Options (optional)
# Increase memory for large builds if needed
# NODE_OPTIONS=--max-old-space-size=4096
